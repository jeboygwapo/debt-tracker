# ── Required ─────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
# On Fly.io set via: flyctl secrets set DATABASE_URL=...
DATABASE_URL=

# ── Environment ───────────────────────────────────────────────────────────────
# "production" enforces SECRET_KEY check and disables debug output
APP_ENV=production

# ── Auth & Registration ───────────────────────────────────────────────────────
# Set true to allow self-signup via /register (default: false = invite-only)
ALLOW_REGISTRATION=false

# ── AI Analysis (optional) ────────────────────────────────────────────────────
# OpenAI key for AI debt analysis feature. Leave blank to disable.
OPENAI_API_KEY=

# Max AI analysis calls per non-admin user per day (admins are exempt, cached hits are free)
AI_DAILY_LIMIT=3

# ── Storage (local/dev only) ──────────────────────────────────────────────────
# Directory for SQLite DB and .env file. Defaults to project root.
# On Fly.io this is handled via a persistent volume mounted at /data.
DATA_DIR=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
